---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import ContactCTA from '../../../components/ContactCTA.astro';
import Hero from '../../../components/Hero.astro';
import Icon from '../../../components/Icon.astro';
import Pill from '../../../components/Pill.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { defaultLocale, isLocale, type Locale } from '../../../i18n/config';
import { sitePath, workIndexPath } from '../../../i18n/paths';
import { assetUrl } from '../../../utils/assetUrl';
import { useUi } from '../../../i18n/ui';
import { workLocaleFromId, workSlugFromId } from '../../../i18n/work';

interface Props {
	entry: CollectionEntry<'work'>;
}

export async function getStaticPaths() {
	const work = await getCollection('work');
	return work
		.map((entry) => {
			const locale = workLocaleFromId(entry.id);
			const slug = workSlugFromId(entry.id);
			if (!locale || !slug) return null;
			return { params: { lang: locale, slug }, props: { entry } };
		})
		.filter((x): x is NonNullable<typeof x> => x !== null);
}

const langParam = Astro.params.lang;
if (!isLocale(langParam)) {
	return Astro.redirect(sitePath(`${defaultLocale}/work/`));
}
const lang: Locale = langParam;

const { entry } = Astro.props;
const { Content } = await render(entry);
const backHref = workIndexPath(lang);
const t = useUi(lang);
---

<BaseLayout lang={lang} title={entry.data.title} description={entry.data.description}>
	<div class="stack gap-20">
		<div class="stack gap-15">
			<header>
				<div class="wrapper stack gap-2">
					<a class="back-link" href={backHref}><Icon icon="arrow-left" /> {t.workBackLink}</a>
					<Hero title={entry.data.title} align="start">
						<div class="details">
							<div class="tags">
								{entry.data.tags.map((t) => <Pill>{t}</Pill>)}
							</div>
							<p class="description">{entry.data.description}</p>
						</div>
					</Hero>
				</div>
			</header>
			<main class="wrapper">
				<div class="stack gap-10 content">
					{entry.data.img && <img src={assetUrl(entry.data.img)} alt={entry.data.img_alt || ''} />}
					<div class="content">
						<Content />
					</div>
				</div>
			</main>
		</div>
		<ContactCTA lang={lang} />
	</div>
</BaseLayout>

<style>
	header {
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--gray-800);
	}

	.back-link {
		display: none;
	}

	.details {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 1.5rem;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		max-width: 100%;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		justify-content: center;
		max-width: 100%;
	}

	.description {
		font-size: var(--text-lg);
		max-width: 54ch;
	}

	.content {
		max-width: 100ch;
		margin-inline: auto;
	}

	.content > :global(* + *) {
		margin-top: 1rem;
	}

	.content :global(h1),
	.content :global(h2),
	.content :global(h3),
	.content :global(h4),
	.content :global(h5) {
		margin: 1.5rem 0;
	}

	.content :global(img) {
		border-radius: 1.5rem;
		box-shadow: var(--shadow-sm);
		background: var(--gradient-subtle);
		border: 1px solid var(--gray-800);
	}

	.content :global(blockquote) {
		font-size: var(--text-lg);
		font-family: var(--font-brand);
		font-weight: 600;
		line-height: 1.1;
		padding-inline-start: 1.5rem;
		border-inline-start: 0.25rem solid var(--accent-dark);
		color: var(--gray-0);
	}

	.content :global(table) {
		width: 100%;
		border-collapse: collapse;
		font-size: var(--text-sm);
		margin: 1.25rem 0;
		border: 1px solid var(--gray-800);
	}

	.content :global(thead) {
		background: var(--gray-900);
	}

	.content :global(th),
	.content :global(td) {
		padding: 0.65rem 0.85rem;
		border: 1px solid var(--gray-800);
		vertical-align: middle;
		text-align: center;
	}

	.content :global(th) {
		font-weight: 600;
		font-family: var(--font-brand);
	}

	.content :global(td code) {
		font-size: 0.9em;
	}

	.content :global(.table-with-total-footer tbody tr:last-child td) {
		font-weight: 600;
		background: var(--gray-900);
	}

	.content :global(table) {
		border-collapse: collapse;
		width: 100%;
	}

	.content :global(th) {
		background: #581c87;
		color: white;
		padding: 0.6rem;
	}

	.content :global(td) {
		padding: 0.6rem;
		border-top: 1px solid var(--gray-800);
	}

	.back-link,
	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.back-link:hover,
	.back-link:focus,
	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.back-link {
			display: block;
			align-self: flex-start;
		}

		.details {
			flex-direction: row;
			gap: 2.5rem;
			align-items: flex-start;
		}

		.tags {
			justify-content: flex-start;
		}

		.content :global(blockquote) {
			font-size: var(--text-2xl);
		}
	}
</style>
