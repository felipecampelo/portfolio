---
import { getCollection } from 'astro:content';
import { defaultLocale } from '../../i18n/config';
import { sitePath } from '../../i18n/paths';
import { workSlugFromId } from '../../i18n/work';

export async function getStaticPaths() {
	const work = await getCollection('work');
	const slugs = new Set<string>();
	for (const e of work) {
		slugs.add(workSlugFromId(e.id));
	}
	return [...slugs].map((slug) => ({ params: { slug } }));
}

const raw = Astro.params.slug;
const slug =
	typeof raw === 'string' ? raw : Array.isArray(raw) ? raw.join('/') : '';
if (!slug) {
	return Astro.redirect(sitePath(`${defaultLocale}/work/`), 302);
}
return Astro.redirect(sitePath(`${defaultLocale}/work/${slug}/`), 302);
---
