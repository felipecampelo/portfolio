---
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { useUi } from '../i18n/ui';

const lang = 'pt';
const t = useUi(lang);
---

<BaseLayout lang={lang} title={t.notFoundTitle} description={t.notFoundDescription}>
	<Hero title={t.notFoundHero} tagline={t.notFoundTagline} />
</BaseLayout>
