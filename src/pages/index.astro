---
import { getCollection } from 'astro:content';
// Component Imports
import CallToAction from '../components/CallToAction.astro';
// Page section components
import ContactCTA from '../components/ContactCTA.astro';
import Grid from '../components/Grid.astro';
import Hero from '../components/Hero.astro';
import Icon from '../components/Icon.astro';
import Pill from '../components/Pill.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Skills from '../components/Skills.astro';
// Layout import — provides basic page elements: <head>, <nav>, <footer> etc.
import BaseLayout from '../layouts/BaseLayout.astro';

// Content Fetching: List four most recent work projects
const projects = (await getCollection('work'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
	.slice(0, 4);

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/
---

<BaseLayout>
	<div class="stack gap-20 lg:gap-48">
		<div class="wrapper stack gap-8 lg:gap-20">
			<header class="hero">
				<Hero
					title="Olá, meu nome é Felipe Campelo"
					tagline="Engenheiro de dados sênior com vasta experiência nas mais variadas tecnologias do mundo moderno."
					align="start"
				>
					<div class="roles">
						<Pill><Icon icon="code" size="1.33em" /> Data Engineer</Pill>
						<Pill><Icon icon="dashboard"size="1.33em" /> Analytics</Pill>
						<Pill><Icon icon="brain"size="1.33em" /> MLOps</Pill>
						<Pill><Icon icon="gears"size="1.33em" /> DevOps</Pill>
						<Pill><Icon icon="microphone-stage" size="1.33em" /> Team Lead</Pill>
					</div>
				</Hero>

				<img
					alt="Felipe Campelo smiling in a red plaid shirt and tortoise shell glasses"
					width="480"
					height="620"
					src="/assets/portrait.jpg"
				/>
			</header>

			<Skills />
		</div>

		<main class="wrapper stack gap-20 lg:gap-48">
			<section class="data-stack-session">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Certificações</h2>
					<p>Aqui estão as principais certificações que obtive durante meu desenvolvimento.</p>
				</header>

				<div class="certifications">

				<div class="databricks">
					<img src="/assets/databricks-de-associate-certification.png" alt="Databricks Data Engineer Associate">
					<img src="/assets/databricks-de-professional-certification.png" alt="Databricks Data Engineer Professional">
					<img src="/assets/databricks-da-associate-certification.png" alt="Databricks Data Analyst Associate">
					<img src="/assets/databricks-mlengineer-associate-certification.png" alt="Databricks ML Engineer Associate">
					<img src="/assets/databricks-fundamentals-certification.png" alt="Databricks Fundamentals">
					<img src="/assets/snowprocore-certification.png" alt="Snowflake SnowPro Core">
					<img src="/assets/gcp-certification.png" alt="Google Cloud Engineer">
					<img src="/assets/aws-cloud-practitioner-certification.png" alt="AWS Cloud Practitioner">
					<img src="/assets/aws-technical-essentials-certification.png" alt="AWS Technical Essentials">
				</div>

				</div>
			</section>
			
			<section class="data-stack-session">
				<header class="section-header stack gap-2 lg:gap-4">
					<h2>Stack de Dados</h2>
					<p>Aqui estão todas as ferramentas que tive contato na minha jornada como Data Engineer, atuando tanto em consultoria como em empresa de produto próprio.</p>
				</header>

				<div class="data-stack">
					<div class="stack-group">
						<h5>Cloud & Infra</h5>
						<div class="stack-grid">
							<div class="stack-card">
								<img 
									src="/assets/aws-logo.png" 
									alt="AWS" 
									style="width: 2.75em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/azure-logo.png" 
									alt="Azure" 
									style="width: 5em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/gcp-logo.png" 
									alt="GCP" 
									style="width: 3.25em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/kubernetes-logo.png" 
									alt="Kubernetes" 
									style="width: 3.25em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/docker-logo.png"
									alt="Docker" 
									style="width: 5em; height: 2.75em;"
								/>
							</div>
						</div>
					</div>

					<div class="stack-group">
						<h5>Data Engineering</h5>
						<div class="stack-grid">
							<div class="stack-card">
								<img
									src="/assets/python-logo.png" 
									alt="Python" 
									style="width: 2em; height: 2.75em;"
								/>
								<span></span></div>
							<div class="stack-card">
								<img
									src="/assets/spark-logo.jpg" 
									alt="AWS" 
									style="width: 2.75em; height: 2.75em;"
								/>
								<span></span></div>
							<div class="stack-card">
								<img
									src="/assets/databricks-logo.png" 
									alt="AWS" 
									style="width: 8em; height: 2.75em;"
								/>
								<span></span></div>
							<div class="stack-card">
								<img
									src="/assets/dbt-logo.png" 
									alt="AWS" 
									style="width: 4em; height: 2.75em;"
								/>
								<span></span></div>
							<div class="stack-card">
								<img
									src="/assets/airflow-logo.png" 
									alt="AWS" 
									style="width: 6em; height: 2.75em;"
								/>
								<span></span></div>
							<div class="stack-card">
								<img
									src="/assets/airbyte-logo.png" 
									alt="Airbyte" 
									style="width: 7em; height: 2.75em;"
								/>
								<span></span></div>
							<div class="stack-card">
								<img
									src="/assets/kafka-logo.png" 
									alt="AWS" 
									style="width: 6em; height: 2.75em;"
								/>
								<span></span></div>
							<div class="stack-card">
								<img
									src="/assets/snowflake-logo.png" 
									alt="Snowflake" 
									style="width: 6em; height: 2.75em;"
								/>
								<span></span></div>
						</div>
					</div>

					<div class="stack-group">
						<h5>Analytics & BI</h5>
						<div class="stack-grid">
							<div class="stack-card">
								<img 
									src="/assets/powerbi-logo.png" 
									alt="Power BI" 
									style="width: 4em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/looker-logo.png" 
									alt="Looker" 
									style="width: 4em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/metabase-logo.png" 
									alt="Metabase" 
									style="width: 2.75em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/sql-logo.png" 
									alt="SQL" 
									style="width: 3.25em; height: 2.75em;"
								/>
							</div>
						</div>
					</div>

					<div class="stack-group">
						<h5>MLOps & Machine Learning</h5>
						<div class="stack-grid">
							<div class="stack-card">
								<img 
									src="/assets/mlflow-logo.png" 
									alt="Mlflow" 
									style="width: 4em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/dab-logo.png" 
									alt="Databricks Asset Bundles" 
									style="width: 4em; height: 2.75em;"
								/>
							</div>
						</div>
					</div>

					<div class="stack-group">
						<h5>DevOps & Observabilidade</h5>
						<div class="stack-grid">
							<div class="stack-card">
								<img 
									src="/assets/prometheus-logo.png" 
									alt="Prometheus" 
									style="width: 5em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/grafana-logo.png" 
									alt="Grafana" 
									style="width: 3.25em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/jenkins-logo.png" 
									alt="Jenkins" 
									style="width: 2.75em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/github-actions-logo.png" 
									alt="Github Actions"
									style="width: 2.75em; height: 2.75em;"
								/>
							</div>
							<div class="stack-card">
								<img 
									src="/assets/bitbucket-pipelines-logo.png" 
									alt="Bitbucket Pipelines" 
									style="width: 2.75em; height: 2.75em;"
								/>
							</div>
						</div>
					</div>
				</div>
			</section>
			<section class="section with-background with-cta">
				<header class="section-header stack gap-2 lg:gap-4">
					<h3>Projetos em Destaque</h3>
					<p>Abaixo estão alguns dos projetos mais relevantes que desenvolvi nos últimos anos, atuando em diferentes contextos e desafios.</p>
				</header>

				<div class="gallery">
					<Grid variant="offset">
						{
							projects.map((project) => (
								<li>
									<PortfolioPreview project={project} />
								</li>
							))
						}
					</Grid>
				</div>

				<div class="cta">
					<CallToAction href="/work/">
						Ver Todos
						<Icon icon="arrow-right" size="1.2em" />
					</CallToAction>
				</div>
			</section>
		</main>

		<ContactCTA />
	</div>
</BaseLayout>

<style>
	.hero {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2rem;
	}

	.roles {
		display: none;
	}

	.hero img {
		aspect-ratio: 5 / 4;
		object-fit: cover;
		object-position: top;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	@media (min-width: 50em) {
		.hero {
			display: grid;
			grid-template-columns: 6fr 4fr;
			padding-inline: 2.5rem;
			gap: 3.75rem;
		}

		.roles {
			margin-top: 0.5rem;
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
		}

		.hero img {
			aspect-ratio: 3 / 4;
			border-radius: 4.5rem;
			object-fit: cover;
		}
	}

	.certifications img {
	height: 150px; /* opcional para padronizar tamanho */
	width: 150;
	}

	/* ====================================================== */

	.section {
		display: grid;
		gap: 2rem;
	}

	.with-background {
		position: relative;
	}

	.with-background::before {
		--hero-bg: var(--bg-image-subtle-2);

		content: '';
		position: absolute;
		pointer-events: none;
		left: 50%;
		width: 100vw;
		aspect-ratio: calc(2.25 / var(--bg-scale));
		top: 0;
		transform: translateY(-75%) translateX(-50%);
		background:
			url('/assets/backgrounds/noise.png') top center/220px repeat,
			var(--hero-bg) center center / var(--bg-gradient-size) no-repeat,
			var(--gray-999);
		background-blend-mode: overlay, normal, normal, normal;
		mix-blend-mode: var(--bg-blend-mode);
		z-index: -1;
	}

	.with-background.bg-variant::before {
		--hero-bg: var(--bg-image-subtle-1);
	}

	.section-header {
		justify-self: center;
		text-align: center;
		max-width: 50ch;
		font-size: var(--text-md);
		color: var(--gray-300);
	}

	.section-header h3 {
		font-size: var(--text-2xl);
	}

	@media (min-width: 50em) {
		.section {
			grid-template-columns: repeat(4, 1fr);
			grid-template-areas: 'header header header header' 'gallery gallery gallery gallery';
			gap: 5rem;
		}

		.section.with-cta {
			grid-template-areas: 'header header header cta' 'gallery gallery gallery gallery';
		}

		.section-header {
			grid-area: header;
			font-size: var(--text-lg);
		}

		.section-header h3 {
			font-size: var(--text-4xl);
		}

		.with-cta .section-header {
			justify-self: flex-start;
			text-align: left;
		}

		.gallery {
			grid-area: gallery;
		}

		.cta {
			grid-area: cta;
		}
	}

	/* ====================================================== */

	.mention-card {
		display: flex;
		height: 7rem;
		justify-content: center;
		align-items: center;
		text-align: center;
		border: 1px solid var(--gray-800);
		border-radius: 1.5rem;
		color: var(--gray-300);
		background: var(--gradient-subtle);
		box-shadow: var(--shadow-sm);
	}

	@media (min-width: 50em) {
		.mention-card {
			border-radius: 1.5rem;
			height: 9.5rem;
		}
	}

/* ======================================================
   Stack de Dados — estilo consistente com Pills
   ====================================================== */

.data-stack-session {
	display: flex;
	flex-direction: column;
	gap: 3rem;
}

/* Header alinhado à esquerda */
.data-stack-session .section-header {
	justify-self: flex-start;
	text-align: left;
	max-width: 60ch;
}

/* Container geral */
.data-stack {
	display: flex;
	flex-direction: column;
	gap: 3rem;
}

/* Grupo */
.stack-group {
	display: flex;
	flex-direction: column;
	gap: 1rem;
}

/* Título da categoria */
.stack-group h5 {
	font-size: var(--text-sm);
	font-weight: 600;
	letter-spacing: 0.12em;
	text-transform: uppercase;
	color: var(--gray-300);
	text-align: left;
}

/* Grid */
.stack-grid {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5rem;
}

/* Botão da ferramenta — MESMO FORMATO DOS PILLS */
.stack-card {
	display: flex;
	padding: 0.5rem 1rem;
	gap: 0.5rem;
	color: var(--accent-text-over);
	border: 1px solid var(--accent-regular);
	border-radius: 999rem;
	font-size: var(--text-md);
	line-height: 1.35;
	white-space: nowrap;
}

/* Ícone PNG */
.stack-card img {
	width: 16px;
	height: 16px;
	object-fit: contain;
	flex-shrink: 0;
	opacity: 0.9;
}

/* Mobile */
@media (max-width: 640px) {
	.stack-grid {
		gap: 0.4rem;
	}
}



</style>
